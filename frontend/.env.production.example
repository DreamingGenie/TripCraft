# 프론트 프로덕션 빌드용 — 실제 값 채워 .env.production 으로 복사(빌드 시 인라인됨)
# API·WS·uploads 는 상대경로(same-origin)라 base URL 불필요.

# 네이버 클라우드 Maps JS 키 (콘솔에 Web 서비스 URL=https://<도메인> 등록 필수)
VITE_NAVER_MAP_CLIENT_ID=your-naver-map-client-id

# 카카오 (개발자콘솔에 Web 플랫폼 도메인 + Redirect URI 등록 필수)
VITE_KAKAO_REST_KEY=your-kakao-rest-key
VITE_KAKAO_REDIRECT_URI=https://tripcraft.thdwjdrl.com/auth/kakao/callback
VITE_KAKAO_LOGOUT_REDIRECT_URI=https://tripcraft.thdwjdrl.com/

# 협업 타이밍(선택 — 미설정 시 코드 기본값 사용)
# VITE_COLLAB_CURSOR_THROTTLE_MS=
# VITE_COLLAB_CURSOR_SMOOTH_MS=
# VITE_COLLAB_KEEPALIVE_MS=
# VITE_COLLAB_RECONNECT_MS=
