VITE_NAVER_MAP_CLIENT_ID=

# 카카오 OAuth 로그인 (authorize 리다이렉트용 REST API 키 + Redirect URI)
# redirect-uri는 백엔드 KAKAO_REDIRECT_URI 및 카카오 콘솔 등록값과 동일해야 함
VITE_KAKAO_REST_KEY=
VITE_KAKAO_REDIRECT_URI=http://localhost:5173/auth/kakao/callback
# 로그아웃 시 카카오 세션 로그아웃 후 돌아올 주소 (카카오 콘솔 "로그아웃 Redirect URI"에 등록)
VITE_KAKAO_LOGOUT_REDIRECT_URI=http://localhost:5173/

# ── 협업 실시간 튜닝(시연↔실서비스) — 미설정 시 코드 기본값(throttle 50 / smooth 45 / keepalive 4000 / reconnect 3000)
#   시연(부드러움): 40 / 45 / 4000 / 2000   ·   실서비스(효율): 80 / 80 / 8000 / 3000
#   ※ smooth는 throttle 이하로 둘 것 — 더 크면 전환이 누적돼 드래그 후 ghost가 한참 따라오는 랙 발생
VITE_COLLAB_CURSOR_THROTTLE_MS=40     # 커서/ghost 전송 throttle(ms). 작을수록 부드럽지만 트래픽↑
VITE_COLLAB_CURSOR_SMOOTH_MS=45       # 수신 보간 transition(ms). throttle 이하 권장. 0=즉시(점프)
VITE_COLLAB_KEEPALIVE_MS=4000         # presence keepalive 주기(ms)
VITE_COLLAB_RECONNECT_MS=2000         # 끊김 후 재연결 지연(ms)
