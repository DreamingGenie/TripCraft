VITE_NAVER_MAP_CLIENT_ID=

# 카카오 OAuth 로그인 (authorize 리다이렉트용 REST API 키 + Redirect URI)
# redirect-uri는 백엔드 KAKAO_REDIRECT_URI 및 카카오 콘솔 등록값과 동일해야 함
VITE_KAKAO_REST_KEY=
VITE_KAKAO_REDIRECT_URI=http://localhost:5173/auth/kakao/callback
# 로그아웃 시 카카오 세션 로그아웃 후 돌아올 주소 (카카오 콘솔 "로그아웃 Redirect URI"에 등록)
VITE_KAKAO_LOGOUT_REDIRECT_URI=http://localhost:5173/

# ── 협업 실시간 튜닝 — 전송 간격·보간이 부하에 따라 자동 조절(적응형). 아래는 그 경계값.
#   전송: 한가하면 THROTTLE_MS(하한)로 자주, 혼잡하면 THROTTLE_MAX_MS(상한)로 back off.
#   보간: 수신 갱신 간격(dt)에 맞춰 동적, SMOOTH_MS는 한가할 때의 상한(글라이드 정도). dt≤이므로 랙 없음.
#   미설정 시 코드 기본값(40 / 90 / 110 / 4000 / 2000). 실서비스 권장: 60 / 120 / 90 / 8000 / 3000
VITE_COLLAB_CURSOR_THROTTLE_MS=40        # 전송 간격 하한(ms, 한가할 때)
VITE_COLLAB_CURSOR_THROTTLE_MAX_MS=90    # 전송 간격 상한(ms, 혼잡 시 back off)
VITE_COLLAB_CURSOR_SMOOTH_MS=110         # 보간 transition 상한(ms, 한가할 때 글라이드)
VITE_COLLAB_KEEPALIVE_MS=4000            # presence keepalive(heartbeat) 주기(ms)
VITE_COLLAB_RECONNECT_MS=2000            # 끊김 후 재연결 지연(ms)
