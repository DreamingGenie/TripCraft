# 로컬용 백엔드 시크릿 — backend-secrets.local.env 로 복사. (git 커밋 금지)
# 외부 API키는 더미여도 앱이 기동된다(이메일 로그인·실시간 협업 테스트엔 불필요).
# 실제 관광지 검색은 시드 데이터로 동작, 이동시간(ODsay/TMap)·AI챗봇·카카오로그인만 키가 있어야 작동.

JWT_SECRET=local-dev-secret-please-change-to-a-long-random-string

# 외부 API (없으면 더미 그대로 — 해당 기능만 비활성)
TOUR_API_KEY=local-dummy
ODSAY_API_KEY=local-dummy
TMAP_API_KEY=local-dummy
GMS_KEY=local-dummy

# 카카오 (로컬에선 콘솔 등록 필요 → 보통 비움. 이메일 회원가입으로 테스트)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_ADMIN_KEY=
KAKAO_REDIRECT_URI=http://localhost:8095/auth/kakao/callback
