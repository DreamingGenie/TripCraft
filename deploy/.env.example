# compose 인터폴레이션용 — 실제 값 채워 deploy/.env 로 복사 (git 커밋 금지)
DOMAIN=tripcraft.thdwjdrl.com

# 앱(컨테이너 nginx) 호스트 노출 포트 — 호스트 nginx 가 이 포트로 프록시(README B 참고)
APP_PORT=8095

# DB (mysql 컨테이너 + 백엔드 공용)
DB_NAME=tripcraft
DB_USERNAME=tripcraft
DB_PASSWORD=change-me-strong
MYSQL_ROOT_PASSWORD=change-me-root-strong
