# 백엔드 시크릿 — 실제 값 채워 deploy/backend-secrets.env 로 복사 (git 커밋 금지)
# DB_* 는 compose 가 주입하므로 여기엔 불필요.

JWT_SECRET=change-me-long-random-secret

# 외부 API
TOUR_API_KEY=
ODSAY_API_KEY=
TMAP_API_KEY=
GMS_KEY=

# 카카오 (Redirect URI 는 콘솔 등록값·프론트와 일치)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_ADMIN_KEY=
KAKAO_REDIRECT_URI=https://tripcraft.thdwjdrl.com/auth/kakao/callback
