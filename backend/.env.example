# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=trip_craft
DB_USERNAME=root
DB_PASSWORD=root

# JWT (256-bit 이상 Base64 인코딩된 시크릿)
JWT_SECRET=

# External APIs
TOUR_API_KEY=
ODSAY_API_KEY=
KAKAO_MAP_API_KEY=
NAVER_MAP_API_KEY=
TMAP_API_KEY=

# 카카오 OAuth 로그인 (REST API 키 — 지도 JS 키와 별개)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:5173/auth/kakao/callback
# 회원탈퇴 시 카카오 연결 해제(unlink)용 Admin 키 (카카오 콘솔 → 앱 키 → Admin 키)
KAKAO_ADMIN_KEY=

# AI (Spring AI - gms OpenAI 호환 프록시)
GMS_KEY=

# ── 협업 presence 튜닝(시연↔실서비스) — 미설정 시 코드 기본값(stale 5000 / evict 2000)
#   ※ 비밀이 아닌 앱 튜닝값이라 본래 application.yml(collab:)이 정석이나, 지금은 .env로 두고 추후 이전 예정.
#   시연(유령 커서 빠르게 제거): 5000 / 2000   ·   실서비스(네트워크 여유·부하↓): 10000 / 3000
COLLAB_PRESENCE_STALE_MS=5000          # 이 시간(ms) 동안 포인터 없으면 stale → 커서 제거
COLLAB_PRESENCE_EVICT_INTERVAL_MS=2000 # stale 정리 스케줄 주기(ms)