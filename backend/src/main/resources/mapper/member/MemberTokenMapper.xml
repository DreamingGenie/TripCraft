<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tripcraft.member.mapper.MemberTokenMapper">

    <resultMap id="tokenMap" type="com.tripcraft.member.domain.MemberToken">
        <id column="id" property="id"/>
        <result column="member_id" property="memberId"/>
        <result column="refresh_token" property="token"/>
        <result column="expires_at" property="expiresAt"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="findByToken" parameterType="string" resultMap="tokenMap">
        SELECT id, member_id, refresh_token, expires_at, created_at
        FROM member_token
        WHERE refresh_token = #{token}
    </select>

    <insert id="insert" parameterType="com.tripcraft.member.domain.MemberToken" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO member_token (member_id, refresh_token, expires_at)
        VALUES (#{memberId}, #{token}, #{expiresAt})
    </insert>

    <delete id="deleteByMemberId" parameterType="long">
        DELETE FROM member_token WHERE member_id = #{memberId}
    </delete>

    <delete id="deleteByToken" parameterType="string">
        DELETE FROM member_token WHERE refresh_token = #{token}
    </delete>

</mapper>
