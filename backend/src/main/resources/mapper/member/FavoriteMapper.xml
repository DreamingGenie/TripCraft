<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tripcraft.member.mapper.FavoriteMapper">

    <resultMap id="favoriteMap" type="com.tripcraft.member.domain.Favorite">
        <id column="id" property="id"/>
        <result column="member_id" property="memberId"/>
        <result column="attraction_id" property="attractionId"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="findByMemberId" parameterType="long" resultMap="favoriteMap">
        SELECT id, member_id, attraction_id, created_at
        FROM favorite
        WHERE member_id = #{memberId}
        ORDER BY created_at DESC
    </select>

    <select id="findByMemberIdAndSigunguCode" resultMap="favoriteMap">
        SELECT f.id, f.member_id, f.attraction_id, f.created_at
        FROM favorite f
        JOIN attraction a ON a.id = f.attraction_id
        WHERE f.member_id = #{memberId}
          AND a.sigungu_code = #{sigunguCode}
    </select>

    <select id="existsByMemberIdAndAttractionId" resultType="boolean">
        SELECT COUNT(*) > 0
        FROM favorite
        WHERE member_id = #{memberId}
          AND attraction_id = #{attractionId}
    </select>

    <insert id="insert" parameterType="com.tripcraft.member.domain.Favorite" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO favorite (member_id, attraction_id)
        VALUES (#{memberId}, #{attractionId})
    </insert>

    <delete id="deleteById" parameterType="long">
        DELETE FROM favorite WHERE id = #{id}
    </delete>

    <delete id="deleteByMemberId" parameterType="long">
        DELETE FROM favorite WHERE member_id = #{memberId}
    </delete>

</mapper>
