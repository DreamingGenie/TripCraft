<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tripcraft.community.mapper.PostCommentMapper">

    <resultMap id="commentDomainMap" type="com.tripcraft.community.domain.PostComment">
        <id     column="id"         property="id"/>
        <result column="post_id"    property="postId"/>
        <result column="member_id"  property="memberId"/>
        <result column="parent_id"  property="parentId"/>
        <result column="content"    property="content"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <!--
        게시글의 댓글 목록 — 최상위 댓글과 대댓글을 함께 반환 (flat list)
        ORDER BY: COALESCE(parent_id, id) → 같은 그룹끼리 묶고,
                  그 안에서 created_at ASC → 등록순 정렬
        Service 레이어에서 parentId 기준으로 트리 구조로 변환함
    -->
    <select id="findByPostId" resultType="com.tripcraft.community.dto.CommentItem">
        SELECT c.id,
               c.post_id                                     AS postId,
               c.parent_id                                   AS parentId,
               COALESCE(m.nickname, '탈퇴한 사용자')          AS authorNickname,
               c.content,
               c.created_at                                  AS createdAt,
               (c.member_id IS NOT NULL AND c.member_id = #{memberId}) AS mine
        FROM post_comment c
        LEFT JOIN member m ON m.id = c.member_id
        WHERE c.post_id = #{postId}
        ORDER BY COALESCE(c.parent_id, c.id) ASC, c.created_at ASC
    </select>

    <!-- 단건 조회 (권한 검증용) -->
    <select id="findById" parameterType="long" resultMap="commentDomainMap">
        SELECT * FROM post_comment WHERE id = #{id}
    </select>

    <!-- 댓글/대댓글 등록 -->
    <insert id="insert" parameterType="com.tripcraft.community.domain.PostComment"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO post_comment (post_id, member_id, parent_id, content)
        VALUES (#{postId}, #{memberId}, #{parentId}, #{content})
    </insert>

    <!-- 댓글 삭제 (ON DELETE CASCADE로 대댓글도 함께 삭제됨) -->
    <delete id="deleteById" parameterType="long">
        DELETE FROM post_comment WHERE id = #{id}
    </delete>

</mapper>
