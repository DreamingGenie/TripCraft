<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tripcraft.community.mapper.PostLikeMapper">

    <resultMap id="likeMap" type="com.tripcraft.community.domain.PostLike">
        <id column="id" property="id"/>
        <result column="post_id" property="postId"/>
        <result column="member_id" property="memberId"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="findByPostIdAndMemberId" resultMap="likeMap">
        SELECT id, post_id, member_id, created_at
        FROM post_like
        WHERE post_id = #{postId} AND member_id = #{memberId}
    </select>

    <select id="countByPostId" parameterType="long" resultType="int">
        SELECT COUNT(*) FROM post_like WHERE post_id = #{postId}
    </select>

    <insert id="insert" parameterType="com.tripcraft.community.domain.PostLike" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO post_like (post_id, member_id) VALUES (#{postId}, #{memberId})
    </insert>

    <delete id="deleteById" parameterType="long">
        DELETE FROM post_like WHERE id = #{id}
    </delete>

    <delete id="deleteByMemberId" parameterType="long">
        DELETE FROM post_like WHERE member_id = #{memberId}
    </delete>

    <select id="findByMemberId" resultType="com.tripcraft.community.dto.PostListItem">
        SELECT <include refid="com.tripcraft.community.mapper.PostMapper.myListSelectBase"/>,
               true AS liked,
               (p.deleted_at IS NOT NULL) AS deleted,
               <include refid="com.tripcraft.community.mapper.PostMapper.profileImageCol"/>,
               <include refid="com.tripcraft.community.mapper.PostMapper.coverImageCol"/>
        FROM post_like pl
        JOIN post p   ON p.id = pl.post_id
        LEFT JOIN member m ON m.id = p.member_id
        <include refid="com.tripcraft.community.mapper.PostMapper.profileImageJoin"/>
        WHERE pl.member_id = #{memberId}
        ORDER BY pl.created_at DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countByMemberId" resultType="int">
        SELECT COUNT(*) FROM post_like WHERE member_id = #{memberId}
    </select>

</mapper>
