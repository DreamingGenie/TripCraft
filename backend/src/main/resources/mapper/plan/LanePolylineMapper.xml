<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tripcraft.plan.mapper.LanePolylineMapper">

    <resultMap id="lanePolylineMap" type="com.tripcraft.plan.domain.LanePolyline">
        <id     column="id"              property="id"/>
        <result column="map_object_key"  property="mapObjectKey"/>
        <result column="route_coords"    property="routeCoords"/>
        <result column="created_at"      property="createdAt"/>
    </resultMap>

    <select id="findByKey" resultMap="lanePolylineMap">
        SELECT * FROM lane_polyline WHERE map_object_key = #{mapObjectKey}
    </select>

    <insert id="insert" parameterType="com.tripcraft.plan.domain.LanePolyline"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO lane_polyline (map_object_key, route_coords)
        VALUES (#{mapObjectKey}, #{routeCoords})
        ON DUPLICATE KEY UPDATE
            route_coords = VALUES(route_coords),
            created_at   = CURRENT_TIMESTAMP
    </insert>

</mapper>
