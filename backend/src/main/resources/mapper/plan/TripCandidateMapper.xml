<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tripcraft.plan.mapper.TripCandidateMapper">

    <resultMap id="candidateMap" type="com.tripcraft.plan.domain.TripCandidate">
        <id column="id" property="id"/>
        <result column="trip_id" property="tripId"/>
        <result column="attraction_id" property="attractionId"/>
        <result column="city_code" property="cityCode"/>
        <result column="source" property="source"/>
        <result column="added_at" property="addedAt"/>
    </resultMap>

    <select id="findById" parameterType="long" resultMap="candidateMap">
        SELECT id, trip_id, attraction_id, city_code, source, added_at
        FROM trip_candidate WHERE id = #{id}
    </select>

    <select id="findByTripId" parameterType="long" resultMap="candidateMap">
        SELECT id, trip_id, attraction_id, city_code, source, added_at
        FROM trip_candidate WHERE trip_id = #{tripId}
        ORDER BY added_at
    </select>

    <select id="existsBlockByCandidateId" parameterType="long" resultType="boolean">
        SELECT COUNT(*) > 0 FROM trip_block WHERE candidate_id = #{candidateId}
    </select>

    <insert id="insert" parameterType="com.tripcraft.plan.domain.TripCandidate" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO trip_candidate (trip_id, attraction_id, city_code, source)
        VALUES (#{tripId}, #{attractionId}, #{cityCode}, #{source})
    </insert>

    <delete id="deleteById" parameterType="long">
        DELETE FROM trip_candidate WHERE id = #{id}
    </delete>

    <delete id="deleteByTripId" parameterType="long">
        DELETE FROM trip_candidate WHERE trip_id = #{tripId}
    </delete>

</mapper>
