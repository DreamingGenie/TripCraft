<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tripcraft.attraction.mapper.AttractionMapper">

    <resultMap id="attractionMap" type="com.tripcraft.attraction.domain.Attraction">
        <id column="id" property="id"/>
        <result column="content_id" property="contentId"/>
        <result column="content_type_id" property="contentTypeId"/>
        <result column="title" property="title"/>
        <result column="sido_code" property="sidoCode"/>
        <result column="sigungu_code" property="sigunguCode"/>
        <result column="addr1" property="addr1"/>
        <result column="addr2" property="addr2"/>
        <result column="latitude" property="latitude"/>
        <result column="longitude" property="longitude"/>
        <result column="tel" property="tel"/>
        <result column="overview" property="overview"/>
        <result column="first_image" property="firstImage"/>
        <result column="api_created_at" property="apiCreatedAt"/>
        <result column="api_modified_at" property="apiModifiedAt"/>
        <result column="synced_at" property="syncedAt"/>
    </resultMap>

    <!-- 공통 WHERE 조건 -->
    <sql id="searchWhere">
        <where>
            <if test="sidoCodes != null and !sidoCodes.isEmpty()">
                AND sido_code IN
                <foreach item="code" collection="sidoCodes" open="(" separator="," close=")">#{code}</foreach>
            </if>
            <if test="sigunguPairs != null and !sigunguPairs.isEmpty()">
                AND (sido_code, sigungu_code) IN
                <foreach item="pair" collection="sigunguPairs" open="(" separator="," close=")">
                    (#{pair.sidoCode}, #{pair.sigunguCode})
                </foreach>
            </if>
            <if test="contentTypeIds != null and !contentTypeIds.isEmpty()">
                AND content_type_id IN
                <foreach item="id" collection="contentTypeIds" open="(" separator="," close=")">#{id}</foreach>
            </if>
            <if test="keyword != null and keyword != ''">
                AND title LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
    </sql>

    <select id="findById" parameterType="long" resultMap="attractionMap">
        SELECT * FROM attraction WHERE id = #{id}
    </select>

    <select id="findAll" resultMap="attractionMap">
        SELECT * FROM attraction ORDER BY id
    </select>

    <select id="findByCondition" parameterType="com.tripcraft.attraction.mapper.AttractionSearchCondition"
            resultMap="attractionMap">
        SELECT * FROM attraction
        <include refid="searchWhere"/>
        ORDER BY sido_code, sigungu_code, content_type_id, id
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countByCondition" parameterType="com.tripcraft.attraction.mapper.AttractionSearchCondition"
            resultType="int">
        SELECT COUNT(*) FROM attraction
        <include refid="searchWhere"/>
    </select>

    <select id="findGroupStats" parameterType="com.tripcraft.attraction.mapper.AttractionSearchCondition"
            resultType="com.tripcraft.attraction.mapper.GroupStatRow">
        SELECT sido_code AS sidoCode, sigungu_code AS sigunguCode,
               content_type_id AS contentTypeId, COUNT(*) AS count
        FROM attraction
        <include refid="searchWhere"/>
        GROUP BY sido_code, sigungu_code, content_type_id
        ORDER BY sido_code, sigungu_code, content_type_id
    </select>

    <insert id="insertAll" parameterType="list">
        INSERT INTO attraction (content_id, content_type_id, title, sido_code, sigungu_code,
                                addr1, addr2, latitude, longitude, tel, overview, first_image,
                                api_created_at, api_modified_at)
        VALUES
        <foreach item="a" collection="list" separator=",">
            (#{a.contentId}, #{a.contentTypeId}, #{a.title}, #{a.sidoCode}, #{a.sigunguCode},
             #{a.addr1}, #{a.addr2}, #{a.latitude}, #{a.longitude}, #{a.tel}, #{a.overview},
             #{a.firstImage}, #{a.apiCreatedAt}, #{a.apiModifiedAt})
        </foreach>
        ON DUPLICATE KEY UPDATE
            title = VALUES(title), addr1 = VALUES(addr1), overview = VALUES(overview),
            api_modified_at = VALUES(api_modified_at), synced_at = CURRENT_TIMESTAMP
    </insert>

    <update id="update" parameterType="com.tripcraft.attraction.domain.Attraction">
        UPDATE attraction
        SET title = #{title}, addr1 = #{addr1}, addr2 = #{addr2}, overview = #{overview},
            api_modified_at = #{apiModifiedAt}, synced_at = CURRENT_TIMESTAMP
        WHERE id = #{id}
    </update>

</mapper>
